<mvc:View
    controllerName="orders.controller.OrderDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">

    <Page title="Dettaglio Ordine" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <ObjectHeader
                title="{detailModel>/Cliente}"
                number="{
                    path: 'detailModel>/ImportoTot',
                    type: 'sap.ui.model.type.Float',
                    formatOptions: { minFractionDigits: 2, maxFractionDigits: 2 }
                }"
                numberUnit="€"
                intro="Ordine n. {detailModel>/NumOrdine}">
                <attributes>
                    <ObjectAttribute title="Stato" text="{detailModel>/StatoTxt}" />
                </attributes>
            </ObjectHeader>

            <Table id="lineItemsTable"
                   items="{detailModel>/Articoli}" 
                   class="sapUiResponsiveMargin"
                   width="auto">
                <headerToolbar>
                    <Toolbar>
                        <Title text="Articoli dell'Ordine" level="H2"/>
                    </Toolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="Codice Articolo"/></Column>
                    <Column><Text text="Nome Articolo"/></Column>
                    <Column hAlign="End"><Text text="Quantità"/></Column>
                    <Column hAlign="End"><Text text="Prezzo"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{detailModel>CodArticolo}" />
                            <Text text="{detailModel>NomeArticolo}" />
                            <Text text="{detailModel>QuantitaOrdine}" />
                            <ObjectNumber number="{detailModel>Importo}" unit="€" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>