<mvc:View
    controllerName="orders.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data"
    displayBlock="true">

    <Page title="{i18n>dashboardTitle}" class="sapUiContentPadding">
        
        <!-- RIGA DELLE MATTONELLE KPI (Novità!) -->
        <HBox class="sapUiSmallMarginBottom" wrap="Wrap">
            
            <GenericTile class="sapUiTinyMarginEnd sapUiTinyMarginBottom" header="Totale Ordini" subheader="Aggiornato ad oggi">
                <TileContent>
                    <NumericContent value="{dashboardModel>/totalOrders}" icon="sap-icon://sys-box" valueColor="Neutral" />
                </TileContent>
            </GenericTile>

            <GenericTile class="sapUiTinyMarginEnd sapUiTinyMarginBottom" header="Fatturato Globale" subheader="In Euro">
                <TileContent>
                    <NumericContent value="{dashboardModel>/totalRevenue}" icon="sap-icon://lead" valueColor="Good" />
                </TileContent>
            </GenericTile>

            <GenericTile class="sapUiTinyMarginEnd sapUiTinyMarginBottom" header="Ordini in Attesa" subheader="Da gestire">
                <TileContent>
                    <NumericContent value="{dashboardModel>/pendingOrders}" icon="sap-icon://alert" valueColor="Error" />
                </TileContent>
            </GenericTile>

        </HBox>

        <!-- GRIGLIA GRAFICI -->
        <layout:Grid defaultSpan="L6 M6 S12">
            
            <!-- GRAFICO A TORTA ESISTENTE -->
            <VBox class="myCustomCard sapUiSmallMargin">
                <Title text="Stato Ordini" level="H2" class="sapUiSmallMargin"/>
                <viz:VizFrame 
                    id="statusChart" 
                    uiConfig="{applicationSet:'fiori'}"
                    height="350px" width="100%" 
                    vizType="pie"
                    vizProperties="{
                        title: { visible: false },
                        plotArea: { 
                            dataLabel: { 
                                visible: true,
                                style: { fontWeight: 'bold' },
                                showTotal: true
                            },
                            colorPalette: [ 
                                '#7b1fa2', 
                                '#9c27b0', 
                                '#ba68c8', 
                                '#e1bee7'
                            ]
                        },
                        legend: {
                            title: { visible: false },
                            label: { style: { fontSize: '14px' } }
                        }
                    }">
                    
                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{statsModel>/Statuses}">
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition name="Stato" value="{statsModel>label}" />
                            </viz.data:dimensions>
                            <viz.data:measures>
                                <viz.data:MeasureDefinition name="Quantità" value="{statsModel>value}" />
                            </viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>

                    <viz:feeds>
                        <viz.feeds:FeedItem uid="size" type="Measure" values="Quantità" />
                        <viz.feeds:FeedItem uid="color" type="Dimension" values="Stato" />
                    </viz:feeds>
                </viz:VizFrame>
            </VBox>

            <!-- SECONDO GRAFICO: Colonne (Ordini per Cliente) -->
            <VBox class="myCustomCard sapUiSmallMargin">
                <Title text="Classifica Ordini per Cliente" level="H2" class="sapUiSmallMargin"/>
                <viz:VizFrame 
                    id="customerChart" 
                    uiConfig="{applicationSet:'fiori'}"
                    height="350px" width="100%" 
                    vizType="column"
                    vizProperties="{
                        title: { visible: false },
                        plotArea: {
                            colorPalette: ['#1976d2'],
                            dataLabel: { 
                                visible: true,
                                style: { fontWeight: 'bold' }
                            }
                        },
                        legend: { visible: false },
                        valueAxis: { title: { visible: false } },
                        categoryAxis: { title: { visible: false } }
                    }">
                    
                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{statsModel>/Customers}">
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition name="Cliente" value="{statsModel>label}" />
                            </viz.data:dimensions>
                            <viz.data:measures>
                                <viz.data:MeasureDefinition name="Numero Ordini" value="{statsModel>value}" />
                            </viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>

                    <viz:feeds>
                        <!-- Nei grafici a colonne, 'size' e 'color' diventano 'valueAxis' e 'categoryAxis' -->
                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Numero Ordini" />
                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Cliente" />
                    </viz:feeds>
                </viz:VizFrame>
            </VBox>

        </layout:Grid>
    </Page>
</mvc:View>