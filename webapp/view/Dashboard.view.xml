<mvc:View controllerName="orders.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:mc="sap.suite.ui.microchart"
    displayBlock="true">
    
    <Page title="Dashboard Statistiche">
        <content>
            <VBox class="sapUiMediumMargin" alignItems="Center">
                
                <Title text="Stato degli Ordini" level="H2" class="sapUiSmallMarginBottom"/>
                <HBox width="400px" justifyContent="Center">
                    <mc:InteractiveDonutChart id="donutChart" segments="{statsModel>/Statuses}">
                        <mc:segments>
                            <mc:InteractiveDonutChartSegment 
                                label="{statsModel>label}" 
                                value="{statsModel>value}" 
                                displayedValue="{statsModel>value} ordini"/>
                        </mc:segments>
                    </mc:InteractiveDonutChart>
                </HBox>

                <Title text="Ordini per Categoria" level="H2" class="sapUiLargeMarginTop sapUiSmallMarginBottom"/>
                <HBox width="400px" justifyContent="Center">
                    <mc:InteractiveBarChart bars="{statsModel>/Categories}" displayedBars="4">
                        <mc:bars>
                            <mc:InteractiveBarChartBar 
                                label="{statsModel>label}" 
                                value="{statsModel>value}" 
                                displayedValue="{statsModel>value}"/>
                        </mc:bars>
                    </mc:InteractiveBarChart>
                </HBox>

            </VBox>
        </content>
    </Page>
    
</mvc:View>