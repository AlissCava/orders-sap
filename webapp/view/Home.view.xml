<mvc:View
    controllerName="orders.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:core="sap.ui.core" 
    xmlns="sap.m">

   <Page id="homePage" title="{i18n>homePageTitle}">
        <content>
            <Table  id="ordersTable" 
                    class="myCustomCard"
                    ariaLabelledBy="tableTitle"
                    items="{/ZES_lista_ordiniSet}" 
                    updateFinished=".onTableUpdateFinished" 
                    growing="true" 
                    growingThreshold="10"> 
                    
                <headerToolbar>
                    <OverflowToolbar>
                        <Title id="tableTitle" text="{summaryModel>/TableTitle}" level="H2" class="sapUiSmallMarginEnd" />
                        
                        <SearchField id="searchField" width="200px" placeholder="{i18n>searchPlaceholder}" tooltip="{i18n>searchPlaceholder}" liveChange=".onSearch" />
                        
                        <Label id="lblStatus" text="{i18n>lblStatusFilter}" labelFor="statusFilter" class="sapUiTinyMarginEnd sapUiSmallMarginBegin" />
                        <Select id="statusFilter" ariaLabelledBy="lblStatus" change=".onSearch" forceSelection="false" width="180px">
                            <core:Item key="" text="{i18n>statusAll}" />
                            <core:Item key="1" text="{i18n>statusCreated}" /> 
                            <core:Item key="2" text="{i18n>statusProcessing}" />
                            <core:Item key="3" text="{i18n>statusTransit}" />
                            <core:Item key="4" text="{i18n>statusClosed}" />
                        </Select>

                        <Label id="lblDate" text="Periodo:" labelFor="dateFilter" class="sapUiTinyMarginEnd sapUiSmallMarginBegin" />
                        <DateRangeSelection id="dateFilter" ariaLabelledBy="lblDate" change=".onSearch" displayFormat="dd/MM/yyyy" width="220px" />
                        
                        <ToolbarSpacer />
                        
                        <Button icon="sap-icon://sort" text="{i18n>btnSort}" press=".onSort" />
                        <Button icon="sap-icon://excel-attachment" text="{i18n>btnExportExcel}" press=".onExport" />
                        <Button icon="sap-icon://add" text="{i18n>btnNewOrder}" type="Emphasized" press=".onNavToCreateOrder" />
                    </OverflowToolbar>
                </headerToolbar>
                
                <columns>
                    <Column><Text id="colNum" text="{i18n>colOrderID}" /></Column>
                    <Column><Text id="colCli" text="{i18n>colCustomer}" /></Column>
                    <Column><Text id="colDat" text="{i18n>colOrderDate}" /></Column> 
                    <Column hAlign="End"><Text id="colImp" text="{i18n>colTotalAmount}" /></Column>
                    <Column><Text id="colSta" text="{i18n>colStatus}" /></Column>
                    
                    <Column width="3rem" hAlign="Center"><Text text="Azioni" visible="false" /></Column>
                </columns>

                <items>
                    <ColumnListItem type="Navigation" press=".onNavToDetail">
                        <cells>
                            <Text text="{NumOrdine}" />
                            <Text text="{Cliente}" />
                            
                            <Text text="{ 
                                path: 'DataOrdine', 
                                formatter: '.formatter.formatItalianDate' 
                            }" />
                            
                            <ObjectNumber number="{ path: 'ImportoTot', formatter: '.formatter.currencyValue' }" />
                            
                            <ObjectStatus 
                                text="{StatoTxt}" 
                                state="{ path: 'StatoTxt', formatter: '.formatter.statusState' }" 
                                icon="{ path: 'StatoTxt', formatter: '.formatter.statusIcon' }" />
                                
                            <Button icon="sap-icon://delete" type="Transparent" press=".onDeleteOrder" tooltip="Elimina Ordine {NumOrdine}" ariaLabel="Elimina Ordine {NumOrdine}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
            
            <VBox class="myCustomCard sapUiSmallMargin" alignItems="End">
                <HBox alignItems="Center" justifyContent="End" width="100%">
                    <Label id="lblTotale" text="{i18n>lblTotalValue}:" design="Bold" class="sapUiSmallMarginEnd" />
                    <ObjectNumber ariaLabelledBy="lblTotale" number="{ path: 'summaryModel>/TotalValue', formatter: '.formatter.currencyValue' }" state="Success" />
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>