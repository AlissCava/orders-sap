<mvc:View
    controllerName="orders.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"> 

   <Page id="homePage" title="{i18n>homePageTitle}">
        <content>
            <Table  id="ordersTable" 
                    class="myCustomCard"
                    items="{/ZES_lista_ordiniSet}" 
                    mode="Delete" 
                    delete=".onDeleteOrder" 
                    updateFinished=".onTableUpdateFinished" 
                    growing="true" 
                    growingThreshold="10"> 
                    
                <headerToolbar>
                    <OverflowToolbar>
                        <SearchField width="300px" placeholder="{i18n>searchPlaceholder}" liveChange=".onSearch" />
                        
                        <Select id="statusFilter" change=".onSearch" forceSelection="false" width="200px">
                            <core:Item key="" text="Tutti gli Stati" />
                            <core:Item key="Nuovo" text="Nuovo" />
                            <core:Item key="In Lavorazione" text="In Lavorazione" />
                            <core:Item key="Completato" text="Completato" />
                            <core:Item key="Cancellato" text="Cancellato" />
                        </Select>
                        <ToolbarSpacer />

                        <Button icon="sap-icon://excel-attachment" text="{i18n>btnExportExcel}" press=".onExport" />
                        <Button icon="sap-icon://add" text="{i18n>btnNewOrder}" type="Emphasized" press=".onNavToCreateOrder" />
                    </OverflowToolbar>
                </headerToolbar>
                
                <columns>
                    <Column><Text text="{i18n>colOrderID}" /></Column>
                    <Column><Text text="{i18n>colCustomer}" /></Column>
                    <Column><Text text="{i18n>colOrderDate}" /></Column> 
                    <Column hAlign="End"><Text text="{i18n>colTotalAmount}" /></Column>
                    <Column hAlign="Center"><Text text="{i18n>colStatus}" /></Column>
                </columns>

                <items>
                    <ColumnListItem type="Navigation" press=".onNavToDetail">
                        <cells>
                            <Text text="{NumOrdine}" />
                            <Text text="{Cliente}" />
                            <Text text="{ 
                                path: 'DataOrdine', 
                                type: 'sap.ui.model.type.Date', 
                                formatOptions: { pattern: 'dd/MM/yyyy' } 
                            }" />
                            
                            <ObjectNumber number="{ path: 'ImportoTot', formatter: '.formatter.currencyValue' }" />
                            
                            <ObjectStatus 
                                text="{StatoTxt}" 
                                state="{ path: 'StatoTxt', formatter: '.formatter.statusState' }" 
                                icon="{ path: 'StatoTxt', formatter: '.formatter.statusIcon' }" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
            
            <VBox class="myCustomCard sapUiSmallMargin" alignItems="End">
                <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                    <Label text="{i18n>lblTotalOrders}" design="Bold" class="sapUiSmallMarginEnd" />
                    <Text text="{summaryModel>/TotalCount}" />
                </HBox>
                <HBox alignItems="Center">
                    <Label text="{i18n>lblTotalValue}" design="Bold" class="sapUiSmallMarginEnd" />
                    <ObjectNumber number="{ path: 'summaryModel>/TotalValue', formatter: '.formatter.currencyValue' }" state="Success" />
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>