<mvc:View
    controllerName="orders.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"> 

    <Page id="page" title="{i18n>homePageTitle}">
        <content>
            <Table  id="ordersTable" 
                    items="{/ZES_lista_ordiniSet}" 
                    mode="Delete" 
                    delete=".onDeleteOrder" 
                    updateFinished=".onTableUpdateFinished" 
                    growing="true" 
                    growingThreshold="10"> 
                    
                <headerToolbar>
                    <OverflowToolbar>
                        <SearchField width="300px" placeholder="{i18n>searchPlaceholder}" liveChange=".onSearch" />
                        <ToolbarSpacer />
                        <Button icon="sap-icon://excel-attachment" text="{i18n>btnExportExcel}" press=".onExport" />
                        <Button icon="sap-icon://add" text="{i18n>btnNewOrder}" type="Emphasized" press=".onOpenAddDialog" />
                    </OverflowToolbar>
                </headerToolbar>
                
                <columns>
                    <Column><Text text="{i18n>colOrderID}" /></Column>
                    <Column><Text text="{i18n>colCustomer}" /></Column>
                    <Column><Text text="{i18n>colOrderDate}" /></Column> 
                    <Column hAlign="End"><Text text="{i18n>colTotalAmount}" /></Column>
                    <Column><Text text="{i18n>colStatus}" /></Column>
                </columns>

                <items>
                    <ColumnListItem type="Navigation" press=".onNavToDetail">
                        <cells>
                            <Text text="{NumOrdine}" />
                            <Text text="{Cliente}" />
                            <Text text="{ 
                                path: 'DataOrdine', 
                                type: 'sap.ui.model.type.Date', 
                                formatOptions: { pattern: 'dd/MM/yyyy' } 
                            }" />
                            <ObjectNumber number="{ImportoTot}" unit="€" />
                            <Text text="{StatoTxt}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
            
            <VBox class="sapUiSmallMargin" alignItems="End">
                <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                    <Label text="{i18n>lblTotalOrders}" design="Bold" class="sapUiSmallMarginEnd" />
                    <Text text="{summaryModel>/TotalCount}" />
                </HBox>
                <HBox alignItems="Center">
                    <Label text="{i18n>lblTotalValue}" design="Bold" class="sapUiSmallMarginEnd" />
                    <ObjectNumber number="{summaryModel>/TotalValue}" unit="€" state="Success" />
                </HBox>
            </VBox>
        </content>

        <dependents>
            <Dialog id="addOrderDialog" title="{i18n>dialogCreateOrderTitle}" contentWidth="400px">
                <content>
                    <VBox class="sapUiSmallMargin">
                        <Label text="{i18n>lblCustomerName}" required="true" />
                        <Input value="{formModel>/newOrder/CustomerName}" placeholder="{i18n>placeholderCustomer}" />
                        
                        <Label text="{i18n>lblArticleCode}" class="sapUiTinyMarginTop" required="true" />
                        <Input value="{formModel>/newOrder/ArticleCode}" placeholder="{i18n>placeholderArticleCodeEx}" />

                        <Label text="{i18n>lblProductName}" class="sapUiTinyMarginTop"/>
                        <Input value="{formModel>/newOrder/ProductName}" placeholder="{i18n>placeholderProduct}" />
                        
                        <Label text="{i18n>lblQuantity}" class="sapUiTinyMarginTop"/>
                        <Input value="{formModel>/newOrder/Quantity}" type="Number" />
                        
                        <Label text="{i18n>lblUnitPrice}" class="sapUiTinyMarginTop"/>
                        <Input value="{formModel>/newOrder/UnitPrice}" type="Number" />
                    </VBox>
                </content>
                <buttons>
                    <Button text="{i18n>btnSave}" type="Emphasized" press=".onSaveOrder" />
                    <Button text="{i18n>btnCancel}" type="Transparent" press=".onCancelOrder" />
                </buttons>
            </Dialog>
        </dependents>
    </Page>
</mvc:View>