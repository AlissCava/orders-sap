<mvc:View
    controllerName="orders.controller.Articles"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m">

    <Page title="{i18n>articlesPageTitle}" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <Table id="articlesTable" items="{/ZES_articoliSet}">
            
           <headerToolbar>
                <OverflowToolbar>
                    <Title text="{i18n>articlesPageTitle}" />
                    <ToolbarSpacer />
                    <Button text="{i18n>btnExportExcel}" icon="sap-icon://excel-attachment" press=".onExportExcel" />
                    <Button text="{i18n>btnNewArticle}" type="Emphasized" press=".onCreateArticle" />
                </OverflowToolbar>
            </headerToolbar>

            <columns>
                <Column><Text text="Code" /></Column>
                <Column><Text text="Name" /></Column>
                <Column><Text text="Price" /></Column>
                <Column><Text text="Available Quantity" /></Column>
            </columns>

            <items>
                <ColumnListItem type="Navigation" press=".onArticlePress">
                    <cells>
                        <Text text="{CodArticolo}" />
                        <Text text="{NomeArticolo}" />
                        <Text text="{Importo} €" />
                        <Text text="{QuantitaDisp}" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
        </content>

        <dependents>
            <Dialog id="addArticleDialog" title="{i18n>dialogCreateArticleTitle}">
                <content>
                    <VBox class="sapUiSmallMargin">
                        <Label text="{i18n>lblArticleCode}" required="true" />
                        <Input value="{articleModel>/newArticle/CodArticolo}" placeholder="{i18n>placeholderArticleCode}" />

                        <Label text="{i18n>lblArticleName}" required="true" class="sapUiTinyMarginTop" />
                        <Input value="{articleModel>/newArticle/NomeArticolo}" placeholder="{i18n>placeholderArticleName}" />

                        <Label text="{i18n>lblAvailableQty}" class="sapUiTinyMarginTop" />
                        <Input value="{articleModel>/newArticle/QuantitaDisp}" type="Number" />

                        <Label text="{i18n>lblPrice}" class="sapUiTinyMarginTop" />
                        <Input value="{articleModel>/newArticle/Importo}" type="Number" placeholder="{i18n>placeholderPrice}" />
                    </VBox>
                </content>
                <buttons>
                    <Button text="{i18n>btnSave}" type="Emphasized" press=".onSaveArticle" />
                    <Button text="{i18n>btnCancel}" press=".onCloseArticleDialog" />
                </buttons>
            </Dialog>
        </dependents>
    </Page>
</mvc:View>