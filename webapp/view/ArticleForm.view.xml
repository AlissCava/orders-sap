<mvc:View
    controllerName="orders.controller.ArticleForm"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">
    
    <Page title="{viewModel>/viewTitle}" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout" title="Article Details">
                <f:content>
                    <Label text="Article Code" required="true" />
                    <Input value="{formModel>/CodArticolo}" editable="false" />

                    <Label text="Article Name" required="true" />
                    <Input value="{formModel>/NomeArticolo}" maxLength="50" />

                    <Label text="Price (€)" />
                    <Input value="{formModel>/Importo}" type="Number" />

                    <Label text="Available Quantity" />
                    <Input value="{formModel>/QuantitaDisp}" type="Number" />
                </f:content>
            </f:SimpleForm>
        </content>
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button text="Save" type="Emphasized" press=".onSave" />
                <Button text="Cancel" type="Transparent" press=".onCancel" />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>