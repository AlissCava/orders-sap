<mvc:View
    controllerName="orders.controller.ArticleForm"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">
    
    <Page title="{viewModel>/viewTitle}" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout" title="{i18n>articlesPageTitle}" class="myCustomCard">
                <f:content>
                    <Label text="{i18n>lblArticleCode}" required="true" />
                    <Input value="{formModel>/CodArticolo}" editable="false" />

                    <Label text="{i18n>lblArticleName}" required="true" />
                    <Input value="{formModel>/NomeArticolo}" maxLength="50" />

                    <Label text="{i18n>lblPrice}" />
                    <Input value="{formModel>/Importo}" type="Number" description="€" textAlign="End" />

                    <Label text="{i18n>lblAvailableQty}" />
                    <Input value="{formModel>/QuantitaDisp}" type="Number" textAlign="End" />
                </f:content>
            </f:SimpleForm>
        </content>

       <footer>
            <OverflowToolbar>
                <ToolbarSpacer/> 
                
                <Button text="{i18n>btnSave}" 
                        type="Emphasized" 
                        icon="sap-icon://save" 
                        press=".onSave" />
                        
                <Button text="{i18n>btnCancel}" 
                        type="Transparent" 
                        icon="sap-icon://sys-cancel" 
                        press=".onCancel" />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>