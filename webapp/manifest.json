{
  "_version": "1.76.0",
  "sap.app": {
    "id": "orders",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZEX_ORDERS_SRV/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0",
          "localUri": "localService/mainService/metadata.xml"
        }
      }
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.143.2",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.suite.ui.microchart": {},
        "sap.ui.layout": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "orders.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "settings": {
          "defaultOperationMode": "Server",
          "defaultBindingMode": "TwoWay",
          "useBatch": false
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app", 
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "orders.view",
        "async": true
      },
      "routes": [
        {
          "name": "RouteHome",
          "pattern": "",
          "target": ["TargetHome"]
        },
        {
          "name": "RouteDashboard",
          "pattern": "dashboard",
          "target": ["TargetDashboard"]
        },
        {
          "name": "RouteArticles",
          "pattern": "articles",
          "target": ["TargetArticles"]
        },
        {
          "name": "RouteOrderDetail",
          "pattern": "orders/{orderId}",
          "target": ["TargetOrderDetail"]
        }
      ],
      "targets": {
        "TargetHome": {
          "viewId": "Home",
          "viewName": "Home"
        },
        "TargetDashboard": {
          "viewId": "Dashboard",
          "viewName": "Dashboard"
        },
        "TargetArticles": {
          "viewId": "Articles",
          "viewName": "Articles"
        },
        "TargetOrderDetail": {
          "viewId": "OrderDetail",
          "viewName": "OrderDetail"
        }
      }
    },
    "rootView": {
      "viewName": "orders.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}